{
    "name": "mytube-api",
    "version": "1.0.0",
    "description": "RSS-first API for a self-hosted YouTube subscription feed reader",
    "main": "index.js",
    "scripts": {
        "start": "node index.js",
        "dev": "node --watch index.js",
        "migrate": "node migrations-runner.js",
        "backup:sqlite": "node sqlite-backup.js backup",
        "restore:sqlite": "node sqlite-backup.js restore",
        "refresh:innertube": "node ../scripts/refresh-innertube-auth.js"
    },
    "dependencies": {
        "axios": "^1.6.0",
        "better-sqlite3": "^12.10.0",
        "compression": "^1.8.1",
        "cors": "^2.8.5",
        "express": "^4.18.2",
        "rss-parser": "^3.13.0"
    }
}
