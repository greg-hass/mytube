# YouTube Data API v3 Key (Optional)
# Get your API key from: https://console.developers.google.com/
# 1. Create a new project
# 2. Enable YouTube Data API v3
# 3. Create credentials (API Key)
# 4. Copy the key below
#
# If you don't provide this key, the app will still work but with limited functionality:
# - Channel information will be basic (title from input)
# - No thumbnails, subscriber counts, or descriptions
# - Channels will still be added and videos will be fetched via RSS

VITE_YOUTUBE_API_KEY=your_youtube_api_key_here
# Optional server-side key for background handle/custom URL resolution
# and primary channel search (search.list, channels.list).
YOUTUBE_API_KEY=your_youtube_api_key_here

# Server API protection. Required by default for all API routes except /api/healthz.
SERVER_API_TOKEN=replace_with_a_long_random_token
# Local trusted-network escape hatch when you deliberately do not want API auth.
# ALLOW_INSECURE_UNAUTHENTICATED_API=true
# Browser CORS / Origin guard. Default allows loopback + private network origins only
# (localhost, 127.0.0.1, 192.168.x.x, 10.x.x.x, 172.16-31.x.x, .local). Set this
# explicitly to comma-separated origins when serving behind a public reverse proxy.
# ALLOWED_ORIGINS=https://feeds.example.com
# API_WRITE_RATE_LIMIT_WINDOW_MS=60000
# API_WRITE_RATE_LIMIT_MAX=30

# Feed refresh configuration
# FEED_REFRESH_ENABLED=true
# FEED_REFRESH_ON_START=true
# FEED_REFRESH_INTERVAL_MINUTES=5

# YouTube HTML scraping is used as a fallback when the Data API key is
# unavailable. YouTube changes the page layout regularly; set this to
# 'false' to disable the scraper (resolve-channel will return 503) if
# it starts producing false negatives.
# YOUTUBE_HTML_PARSING_ENABLED=true
